#--------------------------------------------------------------------
# Example Environment Configuration file
#
# This file can be used as a starting point for your own
# custom .env files, and contains most of the possible settings
# available in a default install.
#
# By default, all of the settings are commented out. If you want
# to override the setting, you must un-comment it by removing the '#'
# at the beginning of the line.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

HOSTPORT=8077

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'http://localhost:8077/'
# If you have trouble with `.`, you could also use `_`.
# app_baseURL = ''
# app.forceGlobalSecureRequests = false
# app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = host.docker.internal
database.default.database = toolkit
database.default.username = admin
database.default.password = Compassion123
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

database.read.hostname = host.docker.internal
database.read.database = toolkit
database.read.username = admin
database.read.password = Compassion123
database.read.DBDriver = MySQLi
database.read.DBPrefix = 
database.read.port = 3306

database.write.hostname = host.docker.internal
database.write.database = toolkit
database.write.username = admin
database.write.password = Compassion123
database.write.DBDriver = MySQLi
database.write.DBPrefix =
database.write.port = 3306

# If you use MySQLi as tests, first update the values of Config\Database::$tests.
database.tests.hostname = host.docker.internal
database.tests.database = toolkit_testing
database.tests.username = admin
database.tests.password = Compassion123
database.tests.DBDriver = MySQLi
database.tests.DBPrefix =
database.tests.charset = utf8mb4
database.tests.DBCollat = utf8mb4_general_ci
database.tests.port = 3306

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

# encryption.key =

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

# session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
# session.savePath = null

