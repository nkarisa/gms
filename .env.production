#----------------------------------------------------------------
# Password salting 
#--------------------------------------------------------------------

SHA256-PASSWORD-SALT=compassion_international_mission_2022m_@_SaLT

#----------------------------------------------------------------
# AWS CREDENTIALS 
#--------------------------------------------------------------------

aws.credentials_profile = default-afr
aws.region = eu-west-1